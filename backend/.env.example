# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service-role key — NEVER expose this to the frontend
# Supabase Dashboard → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Stripe Dashboard → Developers → API keys → Secret key
STRIPE_SECRET_KEY=sk_live_...

# Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from Stripe Dashboard → Products → (each product) → Pricing → Price ID
STRIPE_PRICE_ID_LITE=price_...
STRIPE_PRICE_ID_FULL=price_...

# ── CORS / redirect URLs ───────────────────────────────────────────────────────
# Full URL of the Streamlit frontend (used for checkout success/cancel redirects)
# e.g. https://your-app.streamlit.app  OR  https://your-app.onrender.com
FRONTEND_URL=https://your-app.streamlit.app
