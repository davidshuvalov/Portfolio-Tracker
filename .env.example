# ── Top-level .env.example ────────────────────────────────────────────────────
# This file documents all environment variables used across the project.
# Copy the relevant sections to backend/.env and v2/.streamlit/secrets.toml.

# ── FastAPI backend (backend/.env) ────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...      # SECRET — never expose to frontend
STRIPE_SECRET_KEY=sk_live_...             # SECRET — never expose to frontend
STRIPE_WEBHOOK_SECRET=whsec_...           # SECRET
STRIPE_PRICE_ID_LITE=price_...
STRIPE_PRICE_ID_FULL=price_...
FRONTEND_URL=https://your-app.streamlit.app

# ── Streamlit frontend (v2/.streamlit/secrets.toml) ───────────────────────────
# SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGc...            # PUBLIC — anon key only
# BACKEND_URL=https://your-backend.onrender.com
