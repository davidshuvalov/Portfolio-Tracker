# ── Streamlit secrets — copy to .streamlit/secrets.toml and fill in values ───
# Never commit the real secrets.toml to version control.

# ── Supabase (public / anon key — safe to use in the browser) ─────────────────
SUPABASE_URL = "https://xxxxxxxxxxxxxxxxxxxx.supabase.co"
SUPABASE_ANON_KEY = "eyJhbGc..."      # Dashboard → Settings → API → anon (public)

# ── FastAPI backend URL ────────────────────────────────────────────────────────
# Local dev:  http://localhost:8000
# Production: https://your-backend.onrender.com
BACKEND_URL = "https://your-backend.onrender.com"
